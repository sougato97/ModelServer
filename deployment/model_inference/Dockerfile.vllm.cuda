FROM python:3.10-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates git libgomp1 build-essential \
 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip

# vLLM 0.12.0 pulls torch/torchvision/torchaudio==2.9.0 from PyPI (CUDA cu12 deps via nvidia-* packages).
RUN pip install --no-cache-dir \
    "openai>=1.99.1" "pydantic>=2.12.0" \
    vllm==0.12.0

EXPOSE 8000

ENTRYPOINT ["vllm"]
